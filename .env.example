# 服务监听端口
PORT=3000

# 宿主机 IP，用于生成容器访问链接（必须改为实际 IP）
HOST_IP=192.168.1.100

# 页面标题
SITE_TITLE=Docker Dashboard

# 自动刷新间隔（毫秒），设为 0 关闭自动刷新（默认关闭）
REFRESH_INTERVAL=0

# 严格模式：true = 只显示有 nav.enable=true 的容器
#           false = 显示所有有端口映射的容器（默认）
STRICT_MODE=false

# Docker Socket 路径（Linux/Mac 默认值，通常不需要修改）
# DOCKER_SOCKET=/var/run/docker.sock
